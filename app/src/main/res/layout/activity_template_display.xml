<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Template Preview (Full Screen) -->
    <com.example.cocktailbar.TemplatePreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Bar (hidden when locked) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md"
        android:background="@drawable/bg_gradient_top">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:background="@drawable/bg_button_circle_dark"
            android:src="@drawable/ic_back_white"
            android:scaleType="centerInside"
            android:contentDescription="@string/cancel" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:shadowColor="#80000000"
            android:shadowRadius="4"
            android:shadowDx="1"
            android:shadowDy="1" />

        <View
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size" />

    </LinearLayout>

    <!-- Lock Button (bottom, hidden when locked) -->
    <Button
        android:id="@+id/btnLock"
        style="@style/Widget.CocktailBar.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:text="@string/lock_screen"
        android:textColor="@color/white" />

    <!-- Unlock Button (hidden, appears on triple tap) -->
    <ImageButton
        android:id="@+id/btnUnlock"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="@dimen/spacing_md"
        android:background="@drawable/bg_button_circle_dark"
        android:src="@drawable/ic_unlock"
        android:scaleType="centerInside"
        android:alpha="0.7"
        android:visibility="gone"
        android:contentDescription="@string/unlock" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>