<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Displayed image (full screen) -->
    <ImageView
        android:id="@+id/ivImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="@string/app_name" />

    <!-- Top bar (hidden when locked) -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md"
        android:background="@drawable/bg_gradient_top">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:background="@drawable/bg_button_circle_dark"
            android:src="@drawable/ic_back_white"
            android:scaleType="centerInside"
            android:contentDescription="@string/cancel" />

    </LinearLayout>

    <!-- Lock button (hidden when locked) -->
    <Button
        android:id="@+id/btnLock"
        style="@style/Widget.CocktailBar.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:text="@string/lock_screen"
        android:textColor="@color/white" />

    <!-- Unlock button (appears on triple tap while locked) -->
    <ImageButton
        android:id="@+id/btnUnlock"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="@dimen/spacing_md"
        android:background="@drawable/bg_button_circle_dark"
        android:src="@drawable/ic_unlock"
        android:scaleType="centerInside"
        android:alpha="0.85"
        android:visibility="gone"
        android:contentDescription="@string/unlock" />

</FrameLayout>
