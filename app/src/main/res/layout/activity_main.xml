<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main"
    tools:context=".MainActivity">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="@dimen/spacing_md"
        app:layout_constraintHeight_percent="0.20"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Sync Button Container (Top Left) -->
        <FrameLayout
            android:id="@+id/syncContainer"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnSyncData"
                android:layout_width="@dimen/icon_button_size"
                android:layout_height="@dimen/icon_button_size"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_sync"
                android:scaleType="centerInside"
                android:contentDescription="@string/sync_data" />

            <ImageView
                android:id="@+id/connectionIndicator"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="2dp"
                android:src="@drawable/ic_disconnected"
                android:contentDescription="Connection status" />

        </FrameLayout>

        <!-- Placeholder for right side (keeps logo centered) -->
        <View
            android:id="@+id/rightPlaceholder"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Admin Button (Top Right) - overlaps placeholder when visible -->
        <ImageButton
            android:id="@+id/btnAdminLogin"
            android:layout_width="@dimen/icon_button_size"
            android:layout_height="@dimen/icon_button_size"
            android:background="@drawable/bg_icon_button"
            android:src="@drawable/ic_admin"
            android:scaleType="centerInside"
            android:contentDescription="@string/admin_login"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo (Center - constrained to placeholders) -->
        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/syncContainer"
            app:layout_constraintEnd_toStartOf="@id/rightPlaceholder"
            tools:src="@drawable/ic_launcher_foreground" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Worker Content (shown when NOT logged in) -->
    <LinearLayout
        android:id="@+id/workerContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_xl"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSelectTemplate"
            style="@style/Widget.CocktailBar.Button.Primary"
            android:layout_width="@dimen/button_width"
            android:layout_height="@dimen/button_height"
            android:text="@string/select_template" />

    </LinearLayout>

    <!-- Admin Content (shown when logged in) -->
    <LinearLayout
        android:id="@+id/adminContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_xl"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnDrinks"
            style="@style/Widget.CocktailBar.Button.Primary"
            android:layout_width="@dimen/button_width"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/spacing_md"
            android:text="@string/drinks" />

        <Button
            android:id="@+id/btnTemplates"
            style="@style/Widget.CocktailBar.Button.Primary"
            android:layout_width="@dimen/button_width"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/spacing_md"
            android:text="@string/templates" />

        <Button
            android:id="@+id/btnGallery"
            style="@style/Widget.CocktailBar.Button.Primary"
            android:layout_width="@dimen/button_width"
            android:layout_height="@dimen/button_height"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="@string/gallery" />

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="@dimen/button_width"
            android:layout_height="@dimen/button_height"
            android:text="@string/logout"
            android:textColor="@color/orange_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>