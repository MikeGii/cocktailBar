<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg"
    android:background="@drawable/bg_dialog">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/drinks_settings"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Font Size -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/font_size"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="@dimen/spacing_xs" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_md">

        <SeekBar
            android:id="@+id/seekbarFontSize"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:min="0"
            android:max="20"
            android:progress="6" />

        <TextView
            android:id="@+id/tvFontSizeValue"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="16sp"
            android:textSize="14sp"
            android:textColor="@color/orange_primary"
            android:textStyle="bold"
            android:gravity="end" />

    </LinearLayout>

    <!-- Columns -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/columns"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="@dimen/spacing_xs" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_lg">

        <SeekBar
            android:id="@+id/seekbarColumns"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:min="0"
            android:max="2"
            android:progress="0" />

        <TextView
            android:id="@+id/tvColumnsValue"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="14sp"
            android:textColor="@color/orange_primary"
            android:textStyle="bold"
            android:gravity="end" />

    </LinearLayout>

    <Button
        android:id="@+id/btnClose"
        style="@style/Widget.CocktailBar.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="@string/ok" />

</LinearLayout>